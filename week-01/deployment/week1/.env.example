# Copy this file to `.env` and fill in your own values.
#   cp .env.example .env
#
# Load it into your shell with `set -a; source .env; set +a` before running
# any of the gcloud commands in the README — that exports every variable so
# child processes (gcloud, adk) inherit them.

# Your Google Cloud project ID (the slug, not the numeric project number).
PROJECT_ID=your-gcp-project-id

# Cloud Run region. us-central1 is fine for the lab; pick whatever's closest.
REGION=us-central1

# Cohere API key — used by the agent at runtime via LiteLLM.
# Get one at https://dashboard.cohere.com/api-keys
COHERE_API_KEY=your-cohere-api-key
